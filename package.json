{
  "name": "finance-reconcile-mcp",
  "version": "0.2.0",
  "description": "Read-only MCP server for reconciling SimpleFIN Bridge against Firefly III.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/nalyDzzz/finance-reconcile-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nalyDzzz/finance-reconcile-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/nalyDzzz/finance-reconcile-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "simplefin",
    "firefly-iii",
    "finance",
    "reconciliation",
    "openclaw"
  ],
  "bin": {
    "finance-reconcile-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "account-map.example.json",
    ".env.example"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsx src/index.ts",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
