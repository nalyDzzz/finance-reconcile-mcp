{
  "name": "finance-reconcile-mcp",
  "version": "0.1.0",
  "description": "Read-only MCP server for reconciling SimpleFIN Bridge against Firefly III.",
  "type": "module",
  "bin": {
    "finance-reconcile-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "account-map.example.json",
    ".env.example"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.17",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
